{
  "name": "@asupersync/browser",
  "version": "0.2.7",
  "description": "High-level Browser Edition SDK surface for Asupersync.",
  "homepage": "https://github.com/Dicklesworthstone/asupersync#readme",
  "bugs": {
    "url": "https://github.com/Dicklesworthstone/asupersync/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dicklesworthstone/asupersync.git",
    "directory": "packages/browser"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tracing": {
      "types": "./dist/tracing.d.ts",
      "import": "./dist/tracing.js",
      "default": "./dist/tracing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "@asupersync/browser-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": [
    "asupersync",
    "browser",
    "sdk",
    "structured-concurrency",
    "wasm"
  ]
}
