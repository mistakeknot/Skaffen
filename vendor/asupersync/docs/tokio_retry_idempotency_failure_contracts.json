  "contracts": {
    "retry": [
      {
        "id": "C-RTY-01",
        "title": "Shared Retry Policy Structure",
        "domain": "retry",
        "fields": [
          {"name": "max_attempts", "type": "u32", "default": 3},
          {"name": "initial_delay", "type": "Duration", "default_ms": 100},
          {"name": "max_delay", "type": "Duration", "default_secs": 30},
          {"name": "multiplier", "type": "f64", "default": 2.0},
          {"name": "jitter", "type": "f64", "default": 0.1}
        ],
        "delay_formula": "min(initial_delay * multiplier^(attempt-1), max_delay) * (1 + random(jitter))",
        "reference": "src/combinator/retry.rs",
        "status": "implemented"
      },
      {
        "id": "C-RTY-02",
        "title": "Transaction Retry Eligibility",
        "domain": "retry",
        "eligibility": {
          "postgresql": ["SQLSTATE 40001", "SQLSTATE 40P01"],
          "mysql": ["Error 1213", "Error 1205"],
          "sqlite": ["SQLITE_BUSY", "SQLITE_LOCKED"]
        },
        "non_retryable": [
          "constraint_violation",
          "syntax_error",
          "authentication_failure",
          "connection_failure"
        ],
        "backends_with_retry": ["postgresql", "mysql", "sqlite"],
        "backends_missing_retry": [],
        "status": "implemented"
      },
      {
        "id": "C-RTY-03",
