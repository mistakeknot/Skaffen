  "fault_injection": [
    {
      "type": "connection_failure",
      "description": "Mock ConnectionManager returns Err from connect()",
      "expected": "DbPoolError::Connect propagated, no capacity leak"
    },
    {
      "type": "validation_failure",
      "description": "Mock ConnectionManager returns false from is_valid()",
      "expected": "Connection discarded, new one created, stats updated"
    },
    {
      "type": "intermittent_failure",
      "description": "Alternating success/failure from connect()",
      "expected": "Pool recovers, stats accurate"
    },
    {
      "type": "capacity_exhaustion",
      "description": "All connections checked out, acquire blocked",
      "expected": "DbPoolError::Full, no permanent capacity loss"
    },
    {
      "type": "pool_close",
      "description": "Pool closed while connections idle",
      "expected": "Idle drained, new acquires rejected"
    }
  ],
