{
  "schema_version": "1.0.0",
  "document_id": "tokio_db_pool_transaction_observability_contracts",
  "bead_id": "asupersync-2oh2u.6.5",
  "track": "T6",
  "title": "Pool, Transaction, and Observability Contracts Across Databases",
  "contracts": {
    "pool": [
      {
        "id": "C-POOL-01",
        "title": "Acquire/Release Lifecycle",
        "domain": "pool",
        "operations": ["acquire", "release", "discard", "evict", "lifetime_check"],
        "backends": ["postgresql", "mysql", "sqlite"],
        "cancel_safe": true,
        "status": "defined"
      },
      {
        "id": "C-POOL-02",
        "title": "Configuration Parity",
        "domain": "pool",
        "parameters": [
          {"name": "min_idle", "type": "usize", "default": 1},
          {"name": "max_size", "type": "usize", "default": 10},
          {"name": "connection_timeout", "type": "Duration", "default_secs": 30},
          {"name": "idle_timeout", "type": "Duration", "default_secs": 600},
          {"name": "max_lifetime", "type": "Duration", "default_secs": 3600},
          {"name": "validate_on_checkout", "type": "bool", "default": true}
        ],
        "backends": ["postgresql", "mysql", "sqlite"],
        "status": "defined"
      },
      {
        "id": "C-POOL-03",
        "title": "Health Check Protocol",
        "domain": "pool",
        "health_checks": {
          "postgresql": "SELECT 1",
          "mysql": "SELECT 1 or COM_PING",
          "sqlite": "SELECT 1"
        },
        "requirements": [
          "complete_within_connection_timeout",
          "no_lock_contention",
          "discard_on_failure"
        ],
        "status": "defined"
      },
      {
        "id": "C-POOL-04",
        "title": "Statistics Contract",
        "domain": "pool",
        "required_fields": [
          {"name": "active", "type": "usize"},
          {"name": "idle", "type": "usize"},
          {"name": "total", "type": "usize"},
          {"name": "max_size", "type": "usize"},
          {"name": "waiters", "type": "usize"},
          {"name": "total_acquisitions", "type": "u64"},
          {"name": "total_timeouts", "type": "u64"},
          {"name": "total_validation_failures", "type": "u64"}
        ],
        "status": "partial"
      },
      {
        "id": "C-POOL-05",
        "title": "Cancel-Safety",
        "domain": "pool",
        "phases": [
          {"phase": "wait", "guarantee": "no_resource_leak"},
          {"phase": "hold", "guarantee": "drop_returns_to_pool"},
          {"phase": "transaction", "guarantee": "rollback_before_return"}
        ],
        "status": "defined"
      },
      {
        "id": "C-POOL-06",
        "title": "Backpressure",
        "domain": "pool",
        "requirements": [
          "fifo_queue_ordering",
          "respect_connection_timeout",
          "timeout_returns_error",
          "no_exceed_max_size"
        ],
        "status": "defined"
      },
      {
        "id": "C-POOL-07",
        "title": "Graceful Drain",
        "domain": "pool",
        "steps": [
          "stop_new_acquires",
          "wait_active_returns",
          "disconnect_all",
          "return_after_destroy"
        ],
        "status": "defined"
      }
    ],
    "transaction": [
      {
        "id": "C-TXN-01",
        "title": "Lifecycle",
        "domain": "transaction",
        "lifecycle": ["begin", "execute", "commit_or_rollback"],
        "implicit_rollback_on_drop": true,
        "backends": ["postgresql", "mysql", "sqlite"],
        "status": "implemented"
      },
      {
        "id": "C-TXN-02",
        "title": "Closure-Based Wrapper",
        "domain": "transaction",
        "pattern": "with_transaction(conn, cx, closure)",
        "outcome_mapping": {
          "Ok": "commit",
          "Err": "rollback",
          "Cancelled": "rollback_and_propagate"
        },
        "backends": ["postgresql", "mysql", "sqlite"],
        "status": "implemented"
      },
      {
        "id": "C-TXN-03",
        "title": "Savepoint Support",
        "domain": "transaction",
        "sql_patterns": {
          "postgresql": ["SAVEPOINT name", "RELEASE SAVEPOINT name", "ROLLBACK TO SAVEPOINT name"],
          "mysql": ["SAVEPOINT name", "RELEASE SAVEPOINT name", "ROLLBACK TO SAVEPOINT name"],
          "sqlite": ["SAVEPOINT name", "RELEASE name", "ROLLBACK TO name"]
        },
        "auto_cleanup": true,
        "backends": ["postgresql", "mysql", "sqlite"],
        "status": "implemented"
      },
      {
        "id": "C-TXN-04",
        "title": "Retry Policy",
        "domain": "transaction",
        "policy_fields": ["max_retries", "base_delay", "max_delay"],
        "delay_formula": "min(base_delay * 2^attempt, max_delay)",
        "retry_eligibility": {
          "postgresql": "SQLSTATE 40001",
          "mysql": "Error 1213, Error 1205",
          "sqlite": "SQLITE_BUSY"
        },
        "backends_with_retry": ["postgresql", "mysql", "sqlite"],
        "backends_missing_retry": [],
        "status": "implemented"
      },
      {
        "id": "C-TXN-05",
        "title": "Isolation Level Contract",
        "domain": "transaction",
        "isolation_support": {
          "postgresql": {
            "ReadUncommitted": true,
            "ReadCommitted": true,
            "RepeatableRead": true,
            "Serializable": true,
            "default": "ReadCommitted"
          },
          "mysql": {
            "ReadUncommitted": true,
            "ReadCommitted": true,
            "RepeatableRead": true,
            "Serializable": true,
            "default": "RepeatableRead"
          },
          "sqlite": {
            "ReadUncommitted": false,
            "ReadCommitted": false,
            "RepeatableRead": false,
            "Serializable": true,
            "default": "Serializable"
          }
        },
        "status": "defined"
      }
    ],
    "timeout": [
      {
        "id": "C-TMO-01",
        "title": "Connection Timeout",
        "domain": "timeout",
        "default_secs": 30,
        "error": "PoolError::Timeout",
        "respects_cx_cancel": true,
        "status": "defined"
      },
      {
        "id": "C-TMO-02",
        "title": "Query Timeout",
        "domain": "timeout",
        "status": "not_implemented",
        "cancel_mechanisms": {
          "postgresql": "cancel_key",
          "mysql": "KILL QUERY",
          "sqlite": "sqlite3_interrupt"
        }
      },
      {
        "id": "C-TMO-03",
        "title": "Idle Timeout",
        "domain": "timeout",
        "default_secs": 600,
        "enforcement": "sweep_or_acquire",
        "status": "defined"
      },
      {
        "id": "C-TMO-04",
        "title": "Max Lifetime",
        "domain": "timeout",
        "default_secs": 3600,
        "enforcement": "check_on_release",
        "clock": "monotonic_instant",
        "status": "defined"
      }
    ],
    "observability": [
      {
        "id": "C-OBS-01",
        "title": "Connection Lifecycle Events",
        "domain": "observability",
        "events": [
          {"name": "connection.created", "fields": ["backend", "pool_id", "conn_id"]},
          {"name": "connection.acquired", "fields": ["pool_id", "conn_id", "wait_ms"]},
          {"name": "connection.released", "fields": ["pool_id", "conn_id", "held_ms"]},
          {"name": "connection.evicted", "fields": ["pool_id", "conn_id", "reason"]},
          {"name": "connection.validation_failed", "fields": ["pool_id", "conn_id"]}
        ],
        "status": "not_implemented"
      },
      {
        "id": "C-OBS-02",
        "title": "Transaction Lifecycle Events",
        "domain": "observability",
        "events": [
          {"name": "transaction.begin", "fields": ["backend", "isolation", "conn_id"]},
          {"name": "transaction.commit", "fields": ["conn_id", "duration_ms"]},
          {"name": "transaction.rollback", "fields": ["conn_id", "duration_ms", "reason"]},
          {"name": "transaction.retry", "fields": ["conn_id", "attempt", "error"]}
        ],
        "status": "not_implemented"
      },
      {
        "id": "C-OBS-03",
        "title": "Pool Health Metrics",
        "domain": "observability",
        "derived_metrics": [
          {"name": "pool_utilization", "formula": "active / max_size"},
          {"name": "wait_queue_depth", "formula": "waiters"},
          {"name": "timeout_rate", "formula": "total_timeouts / total_acquisitions"},
          {"name": "validation_failure_rate", "formula": "total_validation_failures / total_acquisitions"}
        ],
        "status": "partial"
      },
      {
        "id": "C-OBS-04",
        "title": "Slow Query Detection",
        "domain": "observability",
        "default_threshold_ms": 1000,
        "log_fields": ["query_text_sanitized", "duration_ms", "backend", "conn_id"],
        "status": "not_implemented"
      }
    ],
